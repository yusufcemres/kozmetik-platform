{
  "name": "kozmetik-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Kozmetik ürün, içerik ve ihtiyaç karar destek platformu",
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter api --filter web build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm --parallel -r lint",
    "db:migrate": "pnpm --filter api migration:run",
    "db:seed": "pnpm --filter api seed",
    "db:generate": "pnpm --filter api migration:generate"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "bcrypt"]
  }
}
