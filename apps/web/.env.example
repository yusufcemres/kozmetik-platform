# =============================================================================
# Web app (Next.js 14) — local env
# =============================================================================
# Copy this file to apps/web/.env.local. Next.js automatically loads .env.local.
# These vars are inlined into the client bundle at build time, so they MUST be
# present before `pnpm dev:web` or `pnpm --filter web build`.
#
# The root .env file is read by the API (NestJS), not by Next.js. To avoid
# confusion, keep NEXT_PUBLIC_* vars duplicated in BOTH files.
# -----------------------------------------------------------------------------

# REQUIRED — backend API URL (must include /api/v1 prefix). The web app calls
# this directly AND uses it for the /api/proxy/* rewrite + CSP connect-src.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# REQUIRED — public site URL. Used in sitemap.xml, robots.txt, JSON-LD
# (Organization, BreadcrumbList, WebSite), Open Graph, brand pages.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 (optional). When set, layout.tsx injects gtag.js.
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Sentry browser SDK (optional). Without this, sentry.client.config.ts is a no-op.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/YYYYYY
# NEXT_PUBLIC_SENTRY_RELEASE=local-dev
# Sentry source map upload (production only, build-time secret):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=revela-web

# Web Push public key (optional). Required ONLY if you test browser push
# notifications. Without it, the subscribe button is hidden.
# NEXT_PUBLIC_VAPID_KEY=

# Feature flags — set NEXT_PUBLIC_FEATURE_<KEY>=true to enable. See
# apps/web/src/lib/features.ts for available keys.
# LAUNCH_CHECKLIST default değerleri (production launch sırasında):
NEXT_PUBLIC_FEATURE_BLOG=true
NEXT_PUBLIC_FEATURE_TITCK_BADGE=true
NEXT_PUBLIC_FEATURE_CROSS_SELL=true
NEXT_PUBLIC_FEATURE_MEDICAL_REVIEWERS=true
# Launch sonrası >100 sorgu/gün olduğunda aç (AI Search pgvector trigger)
NEXT_PUBLIC_FEATURE_AI_SEARCH=true
# Quiz v2 (compatibility score + routine generator), >1000 quiz/ay trigger
NEXT_PUBLIC_FEATURE_QUIZ_V2=true
# Compare blur+reveal paywall — Faz 2'de aktif
NEXT_PUBLIC_FEATURE_COMPARE=false
# Price alerts (sub-feature) — affiliate data biriktiğinde
# NEXT_PUBLIC_FEATURE_PRICEALERTS=false

# Premium OAuth (Faz 3, manuel kullanıcı Cloud Console + FB Developers'tan alır)
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# NEXT_PUBLIC_FACEBOOK_APP_ID=
