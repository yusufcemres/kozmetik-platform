# =============================================================================
# API app (NestJS 11) — local env
# =============================================================================
# The API loads env from the REPO ROOT .env file (not from this directory):
#   apps/api/src/app.module.ts  → ConfigModule envFilePath: '../../.env'
#   apps/api/src/database/data-source.ts → dotenv from '../../.env'
#
# This file exists ONLY as a convenience reference of the API-relevant subset.
# Copy values into the root .env (see /.env.example for the canonical list).
# -----------------------------------------------------------------------------

# REQUIRED — Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=kozmetik
DB_PASS=kozmetik_dev
DB_NAME=kozmetik_platform
DB_SSL=false
DB_MIGRATIONS_RUN=true
DB_SYNC=false

# Used by data-source.ts (TypeORM CLI) and seed scripts under
# src/database/seeds/*.js — set this if you run migrations/seeds manually.
# DATABASE_URL=postgresql://kozmetik:kozmetik_dev@localhost:5432/kozmetik_platform

# REQUIRED — JWT
JWT_SECRET=replace-me-with-a-long-random-string-min-32-chars
JWT_EXPIRY=7d

# OPTIONAL — Redis (cache disables gracefully if unset)
REDIS_URL=redis://localhost:6379

# Ports + env
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:3000
SWAGGER_PUBLIC=true

# OPTIONAL — vision/AI (smart-scan + skin-analysis)
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# 3. fallback provider (Faz 1 polish 2026-05-19) — quota dolarsa OpenAI vision
# OPENAI_API_KEY=

# OPTIONAL — Resend (transactional mail)
# RESEND_API_KEY=
# MAIL_FROM='REVELA <no-reply@revela.com.tr>'
# SITE_URL=https://revela.com.tr

# OPTIONAL — Premium OAuth (Faz 3, 2026-05-18)
# GOOGLE_OAUTH_CLIENT_ID=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# OPTIONAL — PayTR Premium payments (Faz 3, merchant onayı sonrası)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=1  # 1 = test, 0 = canlı

# OPTIONAL — Premium reminder cron 09:30 TR (skin-analysis 09:00 ile çakışmadan)
# (Cron schedule koddan, env yok)

# DB pool tuning (Madde 10 audit, Migration 033 ile birlikte)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT_MS=180000
# DB_CONNECTION_TIMEOUT_MS=10000
# DB_STATEMENT_TIMEOUT_MS=30000

# OPTIONAL — affiliate
# TRENDYOL_AFFILIATE_ID=
# HEPSIBURADA_AFFILIATE_ID=
# AMAZON_ASSOCIATE_TAG=

# OPTIONAL — push
# VAPID_PRIVATE_KEY=
