# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=kozmetik
DB_PASS=kozmetik_dev
DB_NAME=kozmetik_platform

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# App
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# Skip DB (initial dev without Docker)
SKIP_DB=false

# Sentry (production only)
# SENTRY_DSN=https://xxx@sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Analytics
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Site URL (for sitemap/robots.ts)
# NEXT_PUBLIC_SITE_URL=https://kozmetik-platform.vercel.app

# Push Notifications (generate with: npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_KEY=
# VAPID_PRIVATE_KEY=

# Production CORS
# WEB_URL=https://kozmetik-platform.vercel.app
